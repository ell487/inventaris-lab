extends layouts/main

block content
  // Page Heading
  .d-sm-flex.align-items-center.justify-content-between.mb-4
    h1.h3.mb-0.text-gray-800 Dashboard Utama
  
  // Content Row 
  .row
    .col-xl-4.col-md-6.mb-4
      .card.border-left-primary.shadow.h-100.py-2
        .card-body
          .row.no-gutters.align-items-center
            .col.mr-2
              .text-xs.font-weight-bold.text-primary.text-uppercase.mb-1 Total Ruangan Lab
              .h5.mb-0.font-weight-bold.text-gray-800 #{totalRuangan} Ruangan
            .col-auto
              i.fas.fa-door-open.fa-2x.text-gray-300
              
    .col-xl-4.col-md-6.mb-4
      .card.border-left-success.shadow.h-100.py-2
        .card-body
          .row.no-gutters.align-items-center
            .col.mr-2
              .text-xs.font-weight-bold.text-success.text-uppercase.mb-1 Draf Pengadaan Aktif
              .h5.mb-0.font-weight-bold.text-gray-800 0 Draf
            .col-auto
              i.fas.fa-clipboard-list.fa-2x.text-gray-300

    .col-xl-4.col-md-6.mb-4
      .card.border-left-warning.shadow.h-100.py-2
        .card-body
          .row.no-gutters.align-items-center
            .col.mr-2
              .text-xs.font-weight-bold.text-warning.text-uppercase.mb-1 Stok BHP Menipis
              .h5.mb-0.font-weight-bold.text-gray-800 Aman
            .col-auto
              i.fas.fa-exclamation-triangle.fa-2x.text-gray-300