extends ../layouts/main

block content
  .mb-4
    h1.h3.text-gray-800 Dashboard Pengelolaan Staf Laboratorium

  .row
    .col-lg-12
      .card.shadow.mb-4
        .card-header.py-3.bg-primary
          h6.m-0.font-weight-bold.text-white 📋 Riwayat Aktivitas & Log Maintenance Aset
        .card-body
          .table-responsive
            table.table.table-bordered.table-hover
              thead
                tr
                  th No
                  th Tanggal
                  th Nama Barang
                  th Kode Label
                  th Deskripsi Kegiatan
                  th BHP Digunakan
                  th Jumlah
              tbody
                if dataLog && dataLog.length > 0
                  each log, index in dataLog
                    tr
                      td #{index + 1}
                      td #{new Date(log.tanggal_maintenance).toLocaleDateString('id-ID')}
                      td #{log.nama_barang || 'Barang Dihapus'}
                      td: span.badge.badge-dark #{log.kode_label_qr || '-'}
                      td #{log.deskripsi_kegiatan}
                      td
                        if log.nama_bhp
                          span.badge.badge-info #{log.nama_bhp}
                        else
                          span.text-muted -
                      td
                        if log.jumlah_bhp_dipakai > 0
                          | #{log.jumlah_bhp_dipakai} Unit
                        else
                          | -
                else
                  tr
                    td.text-center(colspan="7") Belum ada riwayat maintenance yang tercatat.