extends ../layouts/main

block content
  .d-sm-flex.align-items-center.justify-content-between.mb-4
    h1.h3.mb-0.text-gray-800 Kelola Pengguna Lab

  //- BLOK NOTIFIKASI ALERT
  if status === 'updated'
    .alert.alert-success.alert-dismissible.fade.show(role="alert")
      i.fas.fa-check-circle.mr-2
      | Berhasil! Data pengguna telah diperbarui.
      button.close(type="button" data-dismiss="alert" aria-label="Close")
        span(aria-hidden="true") &times;
        
  if status === 'inserted'
    .alert.alert-success.alert-dismissible.fade.show(role="alert")
      i.fas.fa-plus-circle.mr-2
      | Berhasil! Pengguna baru telah ditambahkan.
      button.close(type="button" data-dismiss="alert" aria-label="Close")
        span(aria-hidden="true") &times;
        
  if status === 'deleted'
    .alert.alert-warning.alert-dismissible.fade.show(role="alert")
      i.fas.fa-trash-alt.mr-2
      | Berhasil! Pengguna telah dihapus.
      button.close(type="button" data-dismiss="alert" aria-label="Close")
        span(aria-hidden="true") &times;
        
  if error === 'password_mismatch'
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fas.fa-exclamation-triangle.mr-2
      | Gagal! Password dan Konfirmasi Password tidak cocok.
      button.close(type="button" data-dismiss="alert" aria-label="Close")
        span(aria-hidden="true") &times;

  if error === 'duplicate_username'
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fas.fa-exclamation-triangle.mr-2
      | Gagal! Username tersebut sudah terdaftar di sistem. Silakan gunakan username lain.
      button.close(type="button" data-dismiss="alert" aria-label="Close")
        span(aria-hidden="true") &times;

  .row
    // Form Tambah Pengguna (Kiri)
    .col-xl-4.col-lg-5
      .card.shadow.mb-4
        .card-header.py-3.bg-primary
          h6.m-0.font-weight-bold.text-white Tambah Pengguna Baru
        .card-body
          form(action="/users/tambah" method="POST" onsubmit="return validateForm(this)")
            .form-group
              label Nama Lengkap
              input.form-control(type="text" name="nama" placeholder="Masukkan nama lengkap" required)
            .form-group
              label Username
              input.form-control(type="text" name="username" placeholder="Masukkan username" required)
            .form-group
              label Password
              input.form-control(type="password" name="password" placeholder="Masukkan password" required)
            //- Tambahan Input Confirm Password
            .form-group
              label Konfirmasi Password
              input.form-control(type="password" name="confirm_password" placeholder="Ulangi password" required)
            .form-group
              label Role / Jabatan
              select.form-control(name="role" required)
                option(value="" disabled selected) -- Pilih Role --
                option(value="admin") Admin
                option(value="kepala_lab") Kepala Lab
                option(value="kaprodi") Kaprodi
                option(value="staf_admin") Staf Admin
                option(value="staf_lab") Staf Laboratorium
            button.btn.btn-primary.btn-block(type="submit")
              i.fas.fa-plus.mr-2
              | Simpan Pengguna

    // Tabel Daftar Akun Sistem (Kanan)
    .col-xl-8.col-lg-7
      .card.shadow.mb-4
        .card-header.py-3
          h6.m-0.font-weight-bold.text-primary Daftar Akun Sistem
        .card-body
          .table-responsive
            table.table.table-bordered(width="100%" cellspacing="0")
              thead
                tr
                  th(style="width: 5%") No
                  th Nama
                  th Username
                  th Role
                  th(style="width: 25%") Aksi
              tbody
                if dataUsers && dataUsers.length > 0
                  each usr, index in dataUsers
                    tr
                      td #{index + 1}
                      td #{usr.nama}
                      td #{usr.username}
                      td
                        span.badge.badge-secondary.p-2 #{usr.role.toUpperCase()}
                      td
                        a.btn.btn-warning.btn-sm.mr-2(href=`/users/edit/${usr.id_user}`)
                          i.fas.fa-edit.mr-1
                          | Edit
                        a.btn.btn-danger.btn-sm(href=`/users/hapus/${usr.id_user}` onclick="return confirm('Yakin ingin menghapus pengguna ini?')")
                          i.fas.fa-trash.mr-1
                          | Hapus
                else
                  tr
                    td.text-center(colspan="5") Belum ada data pengguna.

  //- SCRIPT VALIDASI FORM
  script.
    function validateForm(form) {
      const password = form.password.value;
      const confirmPassword = form.confirm_password.value;
      
      if (password !== confirmPassword) {
        alert("Peringatan: Password dan Konfirmasi Password tidak sama!");
        form.confirm_password.focus();
        return false;
      }
      return true;
    }