extends ../layouts/main

block content
  .d-sm-flex.align-items-center.justify-content-between.mb-4
    h1.h3.mb-0.text-gray-800 Edit Data Ruangan

  .row
    .col-lg-6
      .card.shadow.mb-4
        .card-header.py-3
          h6.m-0.font-weight-bold.text-primary Form Modifikasi Ruangan
        .card-body
          form(action=`/ruangan/edit/${ruangan.id_ruangan}` method="POST")
            .form-group
              label.font-weight-bold Nama Ruangan Lama / Baru
              input.form-control(type="text" name="nama_ruangan" value=ruangan.nama_ruangan required autofocus)
            
            th.text-right
              a.btn.btn-secondary.mr-2(href="/ruangan") Kembali
              button.btn.btn-success(type="submit") Update Perubahan