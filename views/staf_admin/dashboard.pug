extends ../layouts/main

block content
  .d-sm-flex.align-items-center.justify-content-between.mb-4
    h1.h3.mb-0.text-gray-800 Dashboard Staf Administrasi

  //- Komponen Filter & Pencarian Profesional
  .card.shadow.mb-4
    .card-body.bg-light
      form(method="GET" action="/staf-admin")
        .row.align-items-end
          .col-md-5.mb-2
            label.small.font-weight-bold.text-dark Cari Judul Draf Pengadaan
            .input-group
              input.form-control(type="text" name="search" placeholder="Ketik kata kunci..." value=filters.search)
          .col-md-4.mb-2
            label.small.font-weight-bold.text-dark Filter Tahun Ajaran
            select.form-control(name="tahun")
              option(value="") -- Semua Tahun --
              each thn in listTahun
                option(value=thn selected=(filters.tahun === thn.toString())) #{thn}
          .col-md-3.mb-2
            button.btn.btn-primary.btn-block(type="submit")
              i.fas.fa-search.mr-1
              | Terapkan Filter
            if filters.search || filters.tahun
              a.btn.btn-secondary.btn-block.btn-sm.mt-1(href="/staf-admin") Reset Filter

  .card.shadow.mb-4
    .card-header.py-3
      h6.m-0.font-weight-bold.text-primary Draf Pengadaan yang Siap Diterima (Status: Locked)
    .card-body
      .table-responsive
        table.table.table-bordered.table-hover(width="100%" cellspacing="0")
          thead
            tr
              th(style="width: 5%") No
              th Judul Draf Pengadaan
              th Tahun Ajaran
              th Status Draf
              th(style="width: 20%") Aksi
          tbody
            if dataDraf && dataDraf.length > 0
              each draf, index in dataDraf
                tr
                  td #{index + 1}
                  td.font-weight-bold #{draf.judul_draf}
                  td #{draf.tahun}
                  td
                    span.badge.badge-warning Locked
                  td
                    a.btn.btn-success.btn-sm.btn-block(href=`/staf-admin/draf/${draf.id_draf}`)
                      i.fas.fa-boxes.mr-1
                      | Cek Item & Terima Barang
            else
              tr
                td.text-center(colspan="5") Tidak ada draf pengadaan yang cocok dengan kriteria filter Anda.