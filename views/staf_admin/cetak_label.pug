extends ../layouts/main

block content
  .d-flex.justify-content-between.align-items-center.mb-4.d-print-none
    h1.h3.text-gray-800 Lembar Cetak QR
    div
      a.btn.btn-secondary.mr-2(href=`/staf-admin/draf/${item.id_draf}`) Kembali
      button.btn.btn-primary(onclick="window.print()")
        i.fas.fa-print.mr-1
        | Cetak Label

  .row
    if dataAssets && dataAssets.length > 0
      each asset in dataAssets
        .col-md-4.col-sm-6.mb-4
          .card.text-center.border-dark(style="max-width: 220px; margin: auto; border: 2px solid #000; box-shadow: 2px 2px 5px rgba(0,0,0,0.1);")
            .card-header.bg-dark.text-white.py-1.small.font-weight-bold INVENTARIS LAB
            .card-body.p-3
              if asset.foto_qr
                img(src=asset.foto_qr style="width: 140px; height: 140px; object-fit: contain;")
              else
                .p-3.bg-light.text-muted.small No QR Image
              h6.font-weight-bold.mt-2.mb-1.text-dark(style="font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;") #{asset.nama_barang}
              div.badge.badge-primary.mb-1.d-block(style="font-size: 11px;") ID: #{asset.kode_label_qr}
              div.badge.badge-secondary.d-block(style="font-size: 10px;") TAHUN: #{asset.tahun_pengadaan}
    else
      .col-12.text-center.py-5
        .text-muted Belum ada data aset yang ter-registrasi untuk dicetak.

  style.
    @media print {
      .d-print-none, #accordionSidebar, .navbar, footer, .sidebar, .navbar-nav { display: none !important; }
      body { background-color: #fff !important; margin: 0; padding: 0; }
      .container-fluid { padding: 0 !important; }
      .card { page-break-inside: avoid; border: 2px solid #000 !important; margin-bottom: 15px !important; }
    }